<?xml version="1.0"?>

<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
]>

<rdf:RDF xmlns="http://example.com/family#"
     xml:base="http://example.com/family"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.com/family"/>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="http://example.com/family#hasChild">
        <rdfs:domain rdf:resource="http://example.com/family#person"/>
        <rdfs:range rdf:resource="http://example.com/family#person"/>
    </owl:ObjectProperty>

    <!-- Classes -->
    <owl:Class rdf:about="http://example.com/family#person"/>
    <owl:Class rdf:about="http://example.com/family#female">
        <rdfs:subClassOf rdf:resource="http://example.com/family#person"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/family#male">
        <owl:equivalentClass>
            <owl:Class>
                <owl:complementOf rdf:resource="http://example.com/family#female"/>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.com/family#person"/>
    </owl:Class>

    <!-- Individuals -->

    <!-- Alice (f) -->
    <owl:NamedIndividual rdf:about="http://example.com/family#alice">
        <rdf:type rdf:resource="http://example.com/family#person"/>
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <hasChild rdf:resource="http://example.com/family#ella"/>
        <hasChild rdf:resource="http://example.com/family#george"/>
        <hasChild rdf:resource="http://example.com/family#fiona"/>
        <hasChild rdf:resource="http://example.com/family#rose"/>
    </owl:NamedIndividual>

    <!-- Bob (m) -->
    <owl:NamedIndividual rdf:about="http://example.com/family#bob">
        <rdf:type rdf:resource="http://example.com/family#person"/>
        <rdf:type rdf:resource="http://example.com/family#male"/>
        <hasChild rdf:resource="http://example.com/family#ella"/>
        <hasChild rdf:resource="http://example.com/family#george"/>
        <hasChild rdf:resource="http://example.com/family#fiona"/>
        <hasChild rdf:resource="http://example.com/family#rose"/>
    </owl:NamedIndividual>

    <!-- Children of Alice & Bob -->
    <owl:NamedIndividual rdf:about="http://example.com/family#ella">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/family#george">
        <rdf:type rdf:resource="http://example.com/family#male"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/family#fiona">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/family#rose">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>

    <!-- Evelyn (f) -->
    <owl:NamedIndividual rdf:about="http://example.com/family#evelyn">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
        <hasChild rdf:resource="http://example.com/family#henry"/>
    </owl:NamedIndividual>

    <!-- William (m) -->
    <owl:NamedIndividual rdf:about="http://example.com/family#william">
        <rdf:type rdf:resource="http://example.com/family#male"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
        <hasChild rdf:resource="http://example.com/family#henry"/>
        <hasChild rdf:resource="http://example.com/family#isabel"/>
    </owl:NamedIndividual>

    <!-- Children of Evelyn & William -->
    <owl:NamedIndividual rdf:about="http://example.com/family#henry">
        <rdf:type rdf:resource="http://example.com/family#male"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/family#isabel">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>

    <!-- Claire (f) -->
    <owl:NamedIndividual rdf:about="http://example.com/family#claire">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
        <hasChild rdf:resource="http://example.com/family#sara"/>
        <hasChild rdf:resource="http://example.com/family#anna"/>
        <hasChild rdf:resource="http://example.com/family#paul"/>
    </owl:NamedIndividual>

    <!-- Children of Claire -->
    <owl:NamedIndividual rdf:about="http://example.com/family#sara">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/family#anna">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/family#paul">
        <rdf:type rdf:resource="http://example.com/family#male"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>

    <!-- Diana (f) -->
    <owl:NamedIndividual rdf:about="http://example.com/family#diana">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
        <hasChild rdf:resource="http://example.com/family#violet"/>
        <hasChild rdf:resource="http://example.com/family#jasmine"/>
    </owl:NamedIndividual>

    <!-- Children of Diana -->
    <owl:NamedIndividual rdf:about="http://example.com/family#violet">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/family#jasmine">
        <rdf:type rdf:resource="http://example.com/family#female"/>
        <rdf:type rdf:resource="http://example.com/family#person"/>
    </owl:NamedIndividual>

</rdf:RDF>
