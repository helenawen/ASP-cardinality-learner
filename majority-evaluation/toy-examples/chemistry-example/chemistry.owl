<?xml version="1.0"?>

<rdf:RDF xmlns="http://example.org/chemistry#"
     xml:base="http://example.org/chemistry"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/chemistry"/>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="http://example.org/chemistry#binds">
        <rdfs:domain rdf:resource="http://example.org/chemistry#atom"/>
        <rdfs:range rdf:resource="http://example.org/chemistry#atom"/>
    </owl:ObjectProperty>

    <!-- Classes -->
    <owl:Class rdf:about="http://example.org/chemistry#atom"/>

    <owl:Class rdf:about="http://example.org/chemistry#hydrogen">
        <rdfs:subClassOf rdf:resource="http://example.org/chemistry#atom"/>
        <owl:disjointWith rdf:resource="http://example.org/chemistry#carbon"/>
        <owl:disjointWith rdf:resource="http://example.org/chemistry#oxygen"/>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/chemistry#carbon">
        <owl:disjointWith rdf:resource="http://example.org/chemistry#hydrogen"/>
        <owl:disjointWith rdf:resource="http://example.org/chemistry#oxygen"/>
        <rdfs:subClassOf rdf:resource="http://example.org/chemistry#atom"/>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/chemistry#oxygen">
        <owl:disjointWith rdf:resource="http://example.org/chemistry#hydrogen"/>
        <owl:disjointWith rdf:resource="http://example.org/chemistry#carbon"/>
        <rdfs:subClassOf rdf:resource="http://example.org/chemistry#atom"/>
    </owl:Class>

    <!-- Individuals -->

   <!-- C1 -->
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#c1">
        <rdf:type rdf:resource="http://example.org/chemistry#atom"/>
        <rdf:type rdf:resource="http://example.org/chemistry#carbon"/>
        <binds rdf:resource="http://example.org/chemistry#h1"/>
        <binds rdf:resource="http://example.org/chemistry#h2"/>
        <binds rdf:resource="http://example.org/chemistry#h3"/>
    </owl:NamedIndividual>

    <!-- C2 -->
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#c2">
        <rdf:type rdf:resource="http://example.org/chemistry#atom"/>
        <rdf:type rdf:resource="http://example.org/chemistry#carbon"/>
        <binds rdf:resource="http://example.org/chemistry#h4"/>
        <binds rdf:resource="http://example.org/chemistry#h5"/>
        <binds rdf:resource="http://example.org/chemistry#c1"/>
        <binds rdf:resource="http://example.org/chemistry#c3"/>
    </owl:NamedIndividual>

   <!-- C3 -->
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#c3">
        <rdf:type rdf:resource="http://example.org/chemistry#carbon"/>
        <rdf:type rdf:resource="http://example.org/chemistry#atom"/>
        <binds rdf:resource="http://example.org/chemistry#h6"/>
        <binds rdf:resource="http://example.org/chemistry#o1"/>
    </owl:NamedIndividual>

    <!-- Children of Alice & Bob -->
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#h1">
        <rdf:type rdf:resource="http://example.org/chemistry#hydrogen"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#h2">
        <rdf:type rdf:resource="http://example.org/chemistry#hydrogen"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#h3">
        <rdf:type rdf:resource="http://example.org/chemistry#hydrogen"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#h4">
        <rdf:type rdf:resource="http://example.org/chemistry#hydrogen"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#h5">
        <rdf:type rdf:resource="http://example.org/chemistry#hydrogen"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/chemistry#h6">
        <rdf:type rdf:resource="http://example.org/chemistry#hydrogen"/>
    </owl:NamedIndividual>

</rdf:RDF>