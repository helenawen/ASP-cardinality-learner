<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns="http://example.org/tree#"
         xml:base="http://example.org/tree">

  <owl:Ontology rdf:about="http://example.org/tree">
    <rdfs:comment>Ontology representing a hierarchical tree with nodes colored Blue and Green, extended to depth 3.</rdfs:comment>
  </owl:Ontology>

  <owl:Class rdf:about="#Node"/>
  <owl:Class rdf:about="#Color"/>

  <owl:Class rdf:about="#Green">
        <rdfs:subClassOf rdf:resource="#Color"/>
  </owl:Class>

  <owl:Class rdf:about="#Blue">
        <rdfs:subClassOf rdf:resource="#Color"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="#hasChild">
    <rdfs:domain rdf:resource="#Node"/>
    <rdfs:range rdf:resource="#Node"/>
  </owl:ObjectProperty>

  <Node rdf:about="#n1">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n2"/>
    <hasChild rdf:resource="#n3"/>
    <hasChild rdf:resource="#n4"/>
  </Node>

  <Node rdf:about="#n2">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n5"/>
    <hasChild rdf:resource="#n6"/>
    <hasChild rdf:resource="#n7"/>
  </Node>

  <Node rdf:about="#n3">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n8"/>
    <hasChild rdf:resource="#n9"/>
    <hasChild rdf:resource="#n10"/>
  </Node>

  <Node rdf:about="#n4">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <Node rdf:about="#n5">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n11"/>
    <hasChild rdf:resource="#n12"/>
    <hasChild rdf:resource="#n13"/>
  </Node>

  <Node rdf:about="#n6">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n14"/>
    <hasChild rdf:resource="#n15"/>
    <hasChild rdf:resource="#n16"/>
  </Node>

  <Node rdf:about="#n7">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <Node rdf:about="#n8">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n17"/>
    <hasChild rdf:resource="#n18"/>
    <hasChild rdf:resource="#n19"/>
  </Node>

  <Node rdf:about="#n9">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n20"/>
    <hasChild rdf:resource="#n21"/>
    <hasChild rdf:resource="#n22"/>
  </Node>

  <Node rdf:about="#n10">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <Node rdf:about="#n11"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#n12"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#n13"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#n14"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#n15"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#n16"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#n17"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#n18"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#n19"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#n20"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#n21"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#n22"><rdf:type rdf:resource="#Green"/></Node>


  <Node rdf:about="#m1">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m2"/>
    <hasChild rdf:resource="#m3"/>
    <hasChild rdf:resource="#m4"/>
  </Node>

  <Node rdf:about="#m2">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m5"/>
    <hasChild rdf:resource="#m6"/>
    <hasChild rdf:resource="#m7"/>
  </Node>

  <Node rdf:about="#m3">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m8"/>
    <hasChild rdf:resource="#m9"/>
    <hasChild rdf:resource="#m10"/>
  </Node>

  <Node rdf:about="#m4">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <Node rdf:about="#m5">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m11"/>
    <hasChild rdf:resource="#m12"/>
    <hasChild rdf:resource="#m13"/>
  </Node>

  <Node rdf:about="#m6">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m14"/>
    <hasChild rdf:resource="#m15"/>
    <hasChild rdf:resource="#m16"/>
  </Node>

  <Node rdf:about="#m7">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <Node rdf:about="#m8">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m17"/>
    <hasChild rdf:resource="#m18"/>
    <hasChild rdf:resource="#m19"/>
  </Node>

  <Node rdf:about="#m9">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m20"/>
    <hasChild rdf:resource="#m21"/>
    <hasChild rdf:resource="#m22"/>
  </Node>

  <Node rdf:about="#m10">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <Node rdf:about="#m11"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#m12"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#m13"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#m14"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#m15"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#m16"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#m17"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#m18"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#m19"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#m20"><rdf:type rdf:resource="#Blue"/></Node>
  <Node rdf:about="#m21"><rdf:type rdf:resource="#Green"/></Node>
  <Node rdf:about="#m22"><rdf:type rdf:resource="#Green"/></Node>

</rdf:RDF>