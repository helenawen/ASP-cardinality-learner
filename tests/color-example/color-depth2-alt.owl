<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns="http://example.org/tree#"
         xml:base="http://example.org/tree">

  <owl:Ontology rdf:about="http://example.org/tree">
    <rdfs:comment>Ontology representing a hierarchical tree with nodes colored Blue and Green.</rdfs:comment>
  </owl:Ontology>

  <!-- ===== CLASSES ===== -->
  <owl:Class rdf:about="#Node"/>
  <owl:Class rdf:about="#Color"/>

  <owl:Class rdf:about="#Green">
        <rdfs:subClassOf rdf:resource="#Color"/>
  </owl:Class>

  <owl:Class rdf:about="#Blue">
        <rdfs:subClassOf rdf:resource="#Color"/>
  </owl:Class>

  <!-- ===== OBJECT PROPERTIES ===== -->
  <owl:ObjectProperty rdf:about="#hasChild">
    <rdfs:domain rdf:resource="#Node"/>
    <rdfs:range rdf:resource="#Node"/>
  </owl:ObjectProperty>

  <!-- ===== INDIVIDUALS: NODES ===== -->
  <!-- Root node -->
  <Node rdf:about="#n1">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n2"/>
    <hasChild rdf:resource="#n3"/>
    <hasChild rdf:resource="#n4"/>
  </Node>

  <!-- Level 1 children -->
  <Node rdf:about="#n2">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n5"/>
    <hasChild rdf:resource="#n6"/>
    <hasChild rdf:resource="#n7"/>
  </Node>

  <Node rdf:about="#n3">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#n8"/>
    <hasChild rdf:resource="#n9"/>
    <hasChild rdf:resource="#n10"/>
  </Node>

  <Node rdf:about="#n4">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <!-- Level 2 children (from n2) -->
  <Node rdf:about="#n5">
    <rdf:type rdf:resource="#Blue"/>
  </Node>

  <Node rdf:about="#n6">
    <rdf:type rdf:resource="#Blue"/>
  </Node>

  <Node rdf:about="#n7">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <!-- Level 2 children (from n3) -->
  <Node rdf:about="#n8">
    <rdf:type rdf:resource="#Blue"/>
  </Node>

  <Node rdf:about="#n9">
    <rdf:type rdf:resource="#Blue"/>
  </Node>

  <Node rdf:about="#n10">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <!-- ===== INDIVIDUALS: NODES GRAPH 2===== -->
  <!-- Root node -->
  <Node rdf:about="#m1">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m2"/>
    <hasChild rdf:resource="#m3"/>
    <hasChild rdf:resource="#m4"/>
  </Node>

  <!-- Level 1 children -->
  <Node rdf:about="#m2">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m5"/>
    <hasChild rdf:resource="#m6"/>
    <hasChild rdf:resource="#m7"/>
  </Node>

  <Node rdf:about="#m3">
    <rdf:type rdf:resource="#Blue"/>
    <hasChild rdf:resource="#m8"/>
    <hasChild rdf:resource="#m9"/>
    <hasChild rdf:resource="#m10"/>
  </Node>

  <Node rdf:about="#m4">
    <rdf:type rdf:resource="#Green"/>
  </Node>

    <!-- Level 2 children (from n2) -->
  <Node rdf:about="#m5">
    <rdf:type rdf:resource="#Blue"/>
  </Node>

  <Node rdf:about="#m6">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <Node rdf:about="#m7">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <!-- Level 2 children (from m3) -->
  <Node rdf:about="#m8">
    <rdf:type rdf:resource="#Blue"/>
  </Node>

  <Node rdf:about="m9">
    <rdf:type rdf:resource="#Green"/>
  </Node>

  <Node rdf:about="#m10">
    <rdf:type rdf:resource="#Green"/>
  </Node>

</rdf:RDF>
