<?xml version="1.0"?>
<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
]>

<rdf:RDF xmlns="http://example.com/test#"
     xml:base="http://example.com/test"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.com/test"/>

    <!-- Roles -->
    <owl:ObjectProperty rdf:about="http://example.com/test#r"/>
    <owl:ObjectProperty rdf:about="http://example.com/test#s"/>
    <owl:ObjectProperty rdf:about="http://example.com/test#t"/>


    <!-- Concept names -->
    <owl:Class rdf:about="http://example.com/test#A"/>
    <owl:Class rdf:about="http://example.com/test#B"/>

    <!-- Individuals -->
    <owl:NamedIndividual rdf:about="http://example.com/test#a1">
        <s rdf:resource="http://example.com/test#a2"/>
        <s rdf:resource="http://example.com/test#a3"/>
        <t rdf:resource="http://example.com/test#a4"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/test#a2">
        <s rdf:resource="http://example.com/test#a3"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/test#a3">
        <rdf:type rdf:resource="http://example.com/test#A"/>
        <r rdf:resource="http://example.com/test#a4"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.com/test#a4">
        <rdf:type rdf:resource="http://example.com/test#A"/>
        <t rdf:resource="http://example.com/test#a4"/>
    </owl:NamedIndividual>
</rdf:RDF>
