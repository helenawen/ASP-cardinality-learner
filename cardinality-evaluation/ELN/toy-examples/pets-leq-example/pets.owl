<?xml version="1.0"?>

<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
]>

<rdf:RDF xmlns="http://example.com/pets#"
     xml:base="http://example.com/pets"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.com/pets"/>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="http://example.com/pets#ownsBird">
        <rdfs:domain rdf:resource="http://example.com/pets#bird"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/pets#ownsCat">
        <rdfs:domain rdf:resource="http://example.com/pets#cat"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.com/pets#ownsDog">
        <rdfs:domain rdf:resource="http://example.com/pets#dog"/>
    </owl:ObjectProperty>

    <!-- Classes -->
    <owl:Class rdf:about="http://example.com/pets#pet"/>
    <owl:Class rdf:about="http://example.com/pets#bird">
        <rdfs:subClassOf rdf:resource="http://example.com/pets#pet"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/pets#cat">
        <rdfs:subClassOf rdf:resource="http://example.com/pets#pet"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/pets#dog">
        <rdfs:subClassOf rdf:resource="http://example.com/pets#pet"/>
    </owl:Class>

    <owl:Class rdf:about="http://example.com/pets#person"/>
    <owl:Class rdf:about="http://example.com/pets#female">
        <rdfs:subClassOf rdf:resource="http://example.com/pets#person"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.com/pets#male">
             <rdfs:subClassOf rdf:resource="http://example.com/pets#person"/>
    </owl:Class>

    <!-- Individuals -->

    <!-- Alice -->
    <owl:NamedIndividual rdf:about="http://example.com/pets#alice">
        <rdf:type rdf:resource="http://example.com/pets#person"/>

        <ownsBird rdf:resource="http://example.com/pets#bird1"/>
        <ownsBird rdf:resource="http://example.com/pets#bird2"/>
        <ownsCat rdf:resource="http://example.com/pets#cat1"/>
        <ownsDog rdf:resource="http://example.com/pets#dog1"/>
    </owl:NamedIndividual>

    <!-- Bob -->
    <owl:NamedIndividual rdf:about="http://example.com/pets#bob">
        <rdf:type rdf:resource="http://example.com/pets#person"/>

        <ownsBird rdf:resource="http://example.com/pets#bird3"/>
        <ownsBird rdf:resource="http://example.com/pets#bird4"/>
        <ownsBird rdf:resource="http://example.com/pets#bird5"/>
        <ownsCat rdf:resource="http://example.com/pets#cat2"/>
        <ownsDog rdf:resource="http://example.com/pets#dog2"/>
    </owl:NamedIndividual>

    <!-- Birds -->
    <owl:NamedIndividual rdf:about="http://example.com/pets#bird1">
        <rdf:type rdf:resource="http://example.com/pets#bird"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/pets#bird2">
        <rdf:type rdf:resource="http://example.com/pets#bird"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/pets#bird3">
        <rdf:type rdf:resource="http://example.com/pets#bird"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/pets#bird4">
        <rdf:type rdf:resource="http://example.com/pets#bird"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/pets#bird5">
        <rdf:type rdf:resource="http://example.com/pets#bird"/>
    </owl:NamedIndividual>

    <!-- Cats -->
    <owl:NamedIndividual rdf:about="http://example.com/pets#cat1">
        <rdf:type rdf:resource="http://example.com/pets#cat"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/pets#cat2">
        <rdf:type rdf:resource="http://example.com/pets#cat"/>
    </owl:NamedIndividual>

    <!-- Dogs -->
    <owl:NamedIndividual rdf:about="http://example.com/pets#dog1">
        <rdf:type rdf:resource="http://example.com/pets#dog"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.com/pets#dog2">
        <rdf:type rdf:resource="http://example.com/pets#dog"/>
    </owl:NamedIndividual>
</rdf:RDF>